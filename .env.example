# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# When api.telegram.org is blocked, point at a reverse proxy (Cloudflare Worker).
# Deploy ./telegram-proxy with wrangler, or use any Bot API-compatible base URL.
# TELEGRAM_API_ROOT=https://your-worker.workers.dev

# Scheduler (every 5 minutes by default)
CRON_SCHEDULE=*/5 * * * *

# Logging: info | warn | error
LOG_LEVEL=info

# Prune posts not seen for this many days
PRUNE_DAYS=14
